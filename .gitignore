.idea/
.vscode/
.vscode-test/
*.iml
*.ipr
*.iws

# =========================
# Logs / Reports
# =========================
*.log
logs/
log/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# =========================
# Environment / Secrets
# =========================
.env
.env.*
!.env.example
!.env.template
*.env.local
*.secret
*.key
*.pem
*.p12
*.jks
*.keystore

# =========================
# Temporary / Cache
# =========================
tmp/
temp/
.cache/
*.tmp
*.swp
*.swo
*.bak

# =========================
# Frontend (Vue / Node / Vite)
# =========================
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.nuxt/
frontend/.output/
frontend/coverage/
frontend/.eslintcache
frontend/.stylelintcache
frontend/.cache/
frontend/.parcel-cache

# JS/TS coverage/cache
.nyc_output
*.lcov
*.tsbuildinfo

# Yarn v3 / PnP
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn-integrity

# Vite temp timestamp files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Optional package manager lock strategy:
# 保留你们实际使用的 lock 文件，不要全忽略
# frontend/package-lock.json
# frontend/yarn.lock
# frontend/pnpm-lock.yaml

# =========================
# Backend (Java / Maven / Spring Boot)
# =========================
backend/target/
backend/build/
backend/out/
backend/.mvn/wrapper/maven-wrapper.jar

# Java compiled files
*.class

# Spring Boot runtime files
backend/*.pid
backend/*.seed
backend/*.pid.lock

# Local Spring config
backend/src/main/resources/application-local.yml
backend/src/main/resources/application-local.yaml
backend/src/main/resources/application-secret.yml
backend/src/main/resources/application-secret.yaml

